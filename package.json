{
  "name": "handlebars-extd",
  "version": "1.0.14",
  "type": "module",
  "description": "40+ Handlebars helpers for comparison, string, math, date, HTML, and more. Works in Node.js and the browser.",
  "main": "dist/build.common.js",
  "module": "dist/build.esm.js",
  "browser": "dist/build.js",
  "types": "types/index.d.ts",
  "scripts": {
    "prebuild": "rm -rf dist types",
    "build": "cross-env NODE_ENV=production rollup -c rollup.esm-and-umd.config.js && cross-env NODE_ENV=production rollup -c rollup.cjs.config.js",
    "prebuild:dev": "rm -rf dist types",
    "build:dev": "cross-env NODE_ENV=development rollup -c rollup.esm-and-umd.config.js && cross-env NODE_ENV=development rollup -c rollup.cjs.config.js",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shumatsumonobu/handlebars-extd.git"
  },
  "files": [
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "dist/*.js",
    "types/*.d.ts",
    "package.json"
  ],
  "keywords": [
    "handlebars",
    "hbs",
    "helpers",
    "template",
    "comparison",
    "string",
    "math",
    "date",
    "html",
    "formatting",
    "typescript"
  ],
  "author": "shumatsumonobu <shumatsumonobu@gmail.com> (https://x.com/shumatsumonobu)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shumatsumonobu/handlebars-extd/issues",
    "email": "shumatsumonobu@gmail.com"
  },
  "homepage": "https://github.com/shumatsumonobu/handlebars-extd#readme",
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/sprintf-js": "^1.1.4",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "moment": "^2.30.1",
    "sprintf-js": "^1.1.3",
    "striptags": "^3.2.0"
  }
}