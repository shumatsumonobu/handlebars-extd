{
  "compilerOptions": {
    // Output
    "target": "ESNext",
    "module": "ESNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationDir": "./types",

    // Module resolution
    "moduleResolution": "bundler",
    "baseUrl": "./",
    "paths": { "~/*": ["src/*"] },
    "esModuleInterop": true,

    // Type checking
    "strict": true,
    "noImplicitAny": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
